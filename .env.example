# ============================================================
# PathFinder AI — Environment Variables Reference
# ============================================================
# Copy this file to .env (backend) and .env.local (frontend)
# NEVER commit .env files to git — they are in .gitignore
# ============================================================


# ════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES
# File: backend/.env  (local development)
# Set in: Render Dashboard > pathfinder-backend > Environment
# ════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# REQUIRED | Render auto-fills this from the linked PostgreSQL service
# Local dev: use sqlite:///./pathfinder.db  OR  your local postgres URL
# Render production: postgresql://user:pass@host/dbname  (auto-set via fromDatabase)
# ⚠ IMPORTANT: Render provides postgres:// — our database.py auto-converts it
DATABASE_URL=sqlite:///./pathfinder.db

# ── Security ────────────────────────────────────────────────
# REQUIRED | Used for JWT token signing — must be a long random string
# Render: set generateValue: true in render.yaml (auto-generated)
# Local: generate with:  python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-long

# ── AI / Gemini ─────────────────────────────────────────────
# REQUIRED | Google Gemini API key for AI Tutor, quiz generation, career roadmaps
# Obtain: https://aistudio.google.com/app/apikey
# Free tier: 15 req/min | Paid tier: higher limits
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ── CORS ────────────────────────────────────────────────────
# REQUIRED in production | Comma-separated list of allowed frontend origins
# Local dev: leave as * or http://localhost:5173
# Render production: set to your exact Render Static Site URL
# Example: https://pathfinder-frontend.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── SkillBridge AI (ATS Resume Checker) ─────────────────────
# OPTIONAL | External ATS microservice URL — has a safe fallback to Gemini
# Default value already set in career.py if not provided
SKILLBRIDGE_ATS_URL=https://skillbridge-ai.onrender.com

# ── Runtime Flags ────────────────────────────────────────────
# Render sets RENDER=true automatically in its environment
# PRODUCTION=true disables hot-reload and local venv setup in run.py
PRODUCTION=false
# RENDER=true  ← Set automatically by Render, do NOT add manually


# ════════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT VARIABLES
# File: frontend/.env.local  (local development)
# Set in: Render Dashboard > pathfinder-frontend > Environment
# ⚠ ALL frontend vars MUST start with VITE_ to be bundled by Vite
# ════════════════════════════════════════════════════════════

# ── Backend API URL ─────────────────────────────────────────
# REQUIRED | Full URL to the deployed backend API
# Local dev: http://localhost:8000/api/v1
# Render production: https://pathfinder-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# ── Firebase — Web App Configuration ────────────────────────
# REQUIRED | Obtain from: Firebase Console > Project Settings > Your Apps > Web
# URL: https://console.firebase.google.com/project/YOUR_PROJECT/settings/general
#
# Steps:
#   1. Go to Firebase Console → Select your project
#   2. Click ⚙ Project Settings → General tab
#   3. Scroll to "Your apps" → Click your web app (or Add app → Web)
#   4. Copy the firebaseConfig object values below

# Firebase API Key (public — safe to expose in frontend bundles)
VITE_FIREBASE_API_KEY=AIzaSyBptGdIbxGonIxzS8O0OuP_fIdAeRoszkE

# Firebase Auth Domain (format: your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=pathfinder-ai-project.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=pathfinder-ai-project

# Firebase Storage Bucket (format: your-project-id.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=pathfinder-ai-project.firebasestorage.app

# Firebase Messaging Sender ID (numeric string)
VITE_FIREBASE_MESSAGING_SENDER_ID=643456407704

# Firebase App ID (format: 1:SENDER_ID:web:HASH)
VITE_FIREBASE_APP_ID=1:643456407704:web:9311802e80ca4e050d98ed

# Firebase Measurement ID (for Google Analytics — optional)
# OPTIONAL | Remove if you don't need Firebase Analytics
VITE_FIREBASE_MEASUREMENT_ID=G-ZJRCBE91MS
