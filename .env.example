# ============================================================
# PathFinder AI — Environment Variables Reference (.env.example)
# ============================================================
# Copy this to .env for local backend development.
# NEVER commit .env to git — it is in .gitignore.
#
# For Render: Set variables in Dashboard → Service → Environment
# For local frontend: create frontend/.env.local with VITE_* vars
# ============================================================


# ════════════════════════════════════════════════════════════
# BACKEND — Set in Render Web Service Environment
# ════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# REQUIRED
# Render automatically fills this from the linked PostgreSQL service.
# Local dev: uses SQLite by default (no setup needed).
# Render: postgresql://user:pass@host:5432/dbname  (auto-provided)
# ⚠ Our database.py auto-converts postgres:// → postgresql://
DATABASE_URL=sqlite:///./pathfinder.db

# ── Security ─────────────────────────────────────────────────
# REQUIRED
# JWT signing secret — must be a long random string.
# Render: use generateValue: true (auto-generated).
# Local: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-a-long-random-secret-minimum-32-chars

# ── Gemini AI ─────────────────────────────────────────────────
# REQUIRED
# Powers: AI Tutor, Quiz generation, Career Roadmap, Interview Prep,
#         ATS fallback, Discussion doubt solver, Flashcards, Mind Maps
# Obtain: https://aistudio.google.com/app/apikey (free tier available)
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ── CORS & Allowed Hosts ──────────────────────────────────────
# Single-service mode: "*" (FastAPI serves the frontend, no cross-origin)
# Separate-service mode: https://your-frontend.onrender.com
CORS_ORIGINS=*

# Allowed Hosts (comma-separated list for production security)
# Single-service / Render: yourdomain.onrender.com,localhost
ALLOWED_HOSTS=*

# ── Firebase Admin SDK (Backend) ─────────────────────────────
# Optional — required if the backend needs to verify Firebase IDs directly.
FIREBASE_PROJECT_ID=pathfinder-ai-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@pathfinder-ai-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# ── SkillBridge AI ATS ───────────────────────────────────────
# OPTIONAL — Resume ATS checker external microservice.
# Has a built-in Gemini fallback — works even if this is unreachable.
SKILLBRIDGE_ATS_URL=https://skillbridge-ai.onrender.com

# ── Runtime Flags ─────────────────────────────────────────────
# Set to true on Render/production to disable hot-reload and venv setup.
# Render also sets RENDER=true automatically.
PRODUCTION=false
PORT=8000

# ── Python Path ───────────────────────────────────────────────
# Required so uvicorn can resolve app.* imports when CWD is backend/
PYTHONPATH=backend


# ════════════════════════════════════════════════════════════
# FRONTEND — Set in frontend/.env.local (local dev)
# For Render single-service: these are NOT needed (auto-detected)
# For Render separate static site: set in Render environment tab
# ════════════════════════════════════════════════════════════

# ── Backend API URL ───────────────────────────────────────────
# OPTIONAL in single-service mode — auto-detected from window.location.origin
# REQUIRED in separate-service mode
# Local dev: http://localhost:8000/api/v1
# Render single-service: NOT needed (same domain)
# Render separate static site: https://pathfinder-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# ── Firebase Web App Configuration ───────────────────────────
# OPTIONAL — app has hardcoded fallback values for the demo project
# To use your own Firebase project:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → Project Settings → General → Your apps → Web
#   3. Copy the firebaseConfig object values below

VITE_FIREBASE_API_KEY=AIzaSyBptGdIbxGonIxzS8O0OuP_fIdAeRoszkE
VITE_FIREBASE_AUTH_DOMAIN=pathfinder-ai-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pathfinder-ai-project
VITE_FIREBASE_STORAGE_BUCKET=pathfinder-ai-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=643456407704
VITE_FIREBASE_APP_ID=1:643456407704:web:9311802e80ca4e050d98ed
VITE_FIREBASE_MEASUREMENT_ID=G-ZJRCBE91MS
