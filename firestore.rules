rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // User Profiles, Student Data, Teacher Data, Parent Data
    match /users/{email} {
      allow read: if isAuthenticated();
      allow write: if isOwner(email) || hasRole('admin');
    }

    // Achievements
    match /achievements/{id} {
      allow read: if isAuthenticated();
      allow write: if hasRole('teacher') || hasRole('admin');
    }

    // Leaderboard
    match /leaderboard/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.recipientEmail == request.auth.token.email);
      allow write: if hasRole('teacher') || hasRole('admin');
    }

    // Messages
    match /messages/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userEmail == request.auth.token.email);
    }
  }
}
